{
  "stitch": {
    "type": "http",
    "url": "https://stitch.googleapis.com/mcp",
    "headers": {
      "X-Goog-Api-Key": "${GOOGLE_API_KEY}"
    }
  },
  "figma": {
    "command": "npx",
    "args": ["-y", "@anthropic-ai/mcp-server-figma"],
    "env": {
      "FIGMA_ACCESS_TOKEN": "${FIGMA_ACCESS_TOKEN}"
    }
  },
  "nanobanana-mcp": {
    "command": "npx",
    "args": ["-y", "@ycse/nanobanana-mcp"],
    "env": {
      "GOOGLE_AI_API_KEY": "${GOOGLE_AI_API_KEY}"
    }
  }
}
