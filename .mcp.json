{
  "stitch": {
    "command": "npx",
    "args": ["-y", "@anthropic/mcp-stitch@latest"]
  },
  "figma": {
    "command": "npx",
    "args": ["-y", "@anthropic/mcp-figma@latest"],
    "env": {
      "FIGMA_ACCESS_TOKEN": "${FIGMA_ACCESS_TOKEN}"
    }
  },
  "nanobanana-mcp": {
    "command": "npx",
    "args": ["-y", "@ycse/nanobanana-mcp"],
    "env": {
      "GOOGLE_AI_API_KEY": "${GOOGLE_AI_API_KEY}"
    }
  }
}
